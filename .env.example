# ─── Blackboard Access ─────────────────────────────────────────────────────────
BLACKBOARD_URL=https://senati.blackboard.com
BLACKBOARD_USER=tu_correo@senati.pe
BLACKBOARD_PASS=tu_contraseña

# ─── Discord ──────────────────────────────────────────────────────────────────
# Crea un webhook en tu canal de Discord: Configuración → Integraciones → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/tu_webhook_id/tu_webhook_token

# ─── Schedule ─────────────────────────────────────────────────────────────────
# 1=Lunes, 2=Martes, ..., 7=Domingo
WEEKLY_DIGEST_DAY=1

# ─── Behavior ─────────────────────────────────────────────────────────────────
# Ruta del archivo de base de datos SQLite
CACHE_FILE_PATH=./notified_assignments.json

# Zona horaria para fechas (IANA timezone)
TIMEZONE=America/Lima

# Timeout en segundos para peticiones HTTP
REQUEST_TIMEOUT_SECONDS=30

# Número máximo de reintentos
MAX_RETRY_ATTEMPTS=3

# Modo headless del navegador (true=sin interfaz gráfica)
HEADLESS=true

# Nivel de logs: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
